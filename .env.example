# Decision Room real-run environment
# Current runtime supports multiple OpenAI-compatible suppliers via configuration.

# --------------------------------------------------
# Routing targets (required)
# --------------------------------------------------
MODEL_TIMEOUT_SEC=45
REAL_RUN_ROUTE=auto

MODEL_DEFAULT_SUPPLIER=qwen
MODEL_DEFAULT_MODEL=qwen-plus

MODEL_ESCALATION_SUPPLIER=glm
MODEL_ESCALATION_MODEL=glm-5

MODEL_FALLBACK_SUPPLIER=minimax
MODEL_FALLBACK_MODEL=MiniMax-M2.5

# --------------------------------------------------
# Supplier configs
# Only the suppliers referenced above are required.
# --------------------------------------------------

# Alibaba Bailian / DashScope
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=your_dashscope_api_key
# QWEN_TIMEOUT_SEC=45

# Z.ai / GLM
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_API_KEY=your_zai_api_key
# GLM_TIMEOUT_SEC=60

# MiniMax
# Confirm your exact endpoint from your account documentation.
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_API_KEY=your_minimax_api_key
# MINIMAX_TIMEOUT_SEC=45
